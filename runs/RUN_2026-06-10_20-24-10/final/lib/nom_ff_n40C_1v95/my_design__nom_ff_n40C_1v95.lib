library (my_design) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1mA";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : -40.0;
  nom_voltage                    : 1.95;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1("0.00050,  0.00136,  0.00370,  0.01006,  0.02736,  0.07440,  0.20234");
  }

  cell ("my_design") {
    area : 746.966 
    is_macro_cell : true;
    pin("clk") {
      direction : input;
      clock : true;
      capacitance : 0.0040;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.01047");
	}
	cell_fall(scalar) {
          values("0.00323");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.01047");
	}
	cell_fall(scalar) {
          values("0.00323");
	}
      }
    }
    pin("in") {
      direction : input;
      capacitance : 0.0040;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.17297");
	}
	fall_constraint(scalar) {
          values("-0.16812");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.18969");
	}
	fall_constraint(scalar) {
          values("0.21182");
	}
      }
    }
    pin("out") {
      direction : output;
      capacitance : 0.0015;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          index_1("0.00050,  0.00136,  0.00370,  0.01006,  0.02736,  0.07440,  0.20234");
          values("0.52972,0.53484,0.54757,0.58037,0.66851,0.90816,1.56022");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00136,  0.00370,  0.01006,  0.02736,  0.07440,  0.20234");
          values("0.01688,0.02274,0.03922,0.08524,0.21174,0.55919,1.50074");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00136,  0.00370,  0.01006,  0.02736,  0.07440,  0.20234");
          values("0.51519,0.52036,0.53206,0.55824,0.62233,0.79431,1.26165");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00136,  0.00370,  0.01006,  0.02736,  0.07440,  0.20234");
          values("0.01720,0.02153,0.03243,0.06095,0.14161,0.36569,0.98827");
	}
      }
    }
    pin("rst") {
      direction : input;
      capacitance : 0.0035;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	fall_constraint(scalar) {
          values("0.00690");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	fall_constraint(scalar) {
          values("0.05222");
	}
      }
    }
  }

}

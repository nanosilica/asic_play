library (my_design) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1mA";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 25.0;
  nom_voltage                    : 1.80;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1("0.00050,  0.00130,  0.00336,  0.00872,  0.02260,  0.05861,  0.15199");
  }

  cell ("my_design") {
    area : 746.966 
    is_macro_cell : true;
    pin("clk") {
      direction : input;
      clock : true;
      capacitance : 0.0040;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.01435");
	}
	cell_fall(scalar) {
          values("0.00613");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.01435");
	}
	cell_fall(scalar) {
          values("0.00613");
	}
      }
    }
    pin("in") {
      direction : input;
      capacitance : 0.0040;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.27027");
	}
	fall_constraint(scalar) {
          values("-0.25956");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.29932");
	}
	fall_constraint(scalar) {
          values("0.33276");
	}
      }
    }
    pin("out") {
      direction : output;
      capacitance : 0.0015;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          index_1("0.00050,  0.00130,  0.00336,  0.00872,  0.02260,  0.05861,  0.15199");
          values("0.79413,0.80076,0.81628,0.85393,0.94924,1.19555,1.83685");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00130,  0.00336,  0.00872,  0.02260,  0.05861,  0.15199");
          values("0.02428,0.03159,0.05072,0.10181,0.23621,0.58797,1.50222");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00130,  0.00336,  0.00872,  0.02260,  0.05861,  0.15199");
          values("0.79350,0.80043,0.81579,0.84866,0.92380,1.11378,1.60551");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00130,  0.00336,  0.00872,  0.02260,  0.05861,  0.15199");
          values("0.02514,0.03087,0.04511,0.08010,0.17306,0.42638,1.07726");
	}
      }
    }
    pin("rst") {
      direction : input;
      capacitance : 0.0035;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	fall_constraint(scalar) {
          values("0.02488");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	fall_constraint(scalar) {
          values("0.06796");
	}
      }
    }
  }

}

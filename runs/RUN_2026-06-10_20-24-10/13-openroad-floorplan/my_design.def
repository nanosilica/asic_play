VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN my_design ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 50000 50000 ) ;
ROW ROW_0 unithd 10120 10880 N DO 64 BY 1 STEP 460 0 ;
ROW ROW_1 unithd 10120 13600 FS DO 64 BY 1 STEP 460 0 ;
ROW ROW_2 unithd 10120 16320 N DO 64 BY 1 STEP 460 0 ;
ROW ROW_3 unithd 10120 19040 FS DO 64 BY 1 STEP 460 0 ;
ROW ROW_4 unithd 10120 21760 N DO 64 BY 1 STEP 460 0 ;
ROW ROW_5 unithd 10120 24480 FS DO 64 BY 1 STEP 460 0 ;
ROW ROW_6 unithd 10120 27200 N DO 64 BY 1 STEP 460 0 ;
ROW ROW_7 unithd 10120 29920 FS DO 64 BY 1 STEP 460 0 ;
ROW ROW_8 unithd 10120 32640 N DO 64 BY 1 STEP 460 0 ;
ROW ROW_9 unithd 10120 35360 FS DO 64 BY 1 STEP 460 0 ;
TRACKS X 230 DO 109 STEP 460 LAYER li1 ;
TRACKS Y 170 DO 147 STEP 340 LAYER li1 ;
TRACKS X 170 DO 147 STEP 340 LAYER met1 ;
TRACKS Y 170 DO 147 STEP 340 LAYER met1 ;
TRACKS X 230 DO 109 STEP 460 LAYER met2 ;
TRACKS Y 230 DO 109 STEP 460 LAYER met2 ;
TRACKS X 340 DO 73 STEP 680 LAYER met3 ;
TRACKS Y 340 DO 73 STEP 680 LAYER met3 ;
TRACKS X 460 DO 54 STEP 920 LAYER met4 ;
TRACKS Y 460 DO 54 STEP 920 LAYER met4 ;
TRACKS X 1700 DO 14 STEP 3400 LAYER met5 ;
TRACKS Y 1700 DO 14 STEP 3400 LAYER met5 ;
COMPONENTS 2 ;
    - _1_ sky130_fd_sc_hd__inv_2 ;
    - _2_ sky130_fd_sc_hd__dfrtp_2 ;
END COMPONENTS
PINS 4 ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL ;
    - in + NET in + DIRECTION INPUT + USE SIGNAL ;
    - out + NET out + DIRECTION OUTPUT + USE SIGNAL ;
    - rst + NET rst + DIRECTION INPUT + USE SIGNAL ;
END PINS
SPECIALNETS 2 ;
    - VGND ( * VNB ) ( * VGND ) + USE GROUND ;
    - VPWR ( * VPB ) ( * VPWR ) + USE POWER ;
END SPECIALNETS
NETS 5 ;
    - _0_ ( _2_ RESET_B ) ( _1_ Y ) + USE SIGNAL ;
    - clk ( PIN clk ) ( _2_ CLK ) + USE SIGNAL ;
    - in ( PIN in ) ( _2_ D ) + USE SIGNAL ;
    - out ( PIN out ) ( _2_ Q ) + USE SIGNAL ;
    - rst ( PIN rst ) ( _1_ A ) + USE SIGNAL ;
END NETS
END DESIGN
